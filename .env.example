# Database
DATABASE_URL="postgresql://user:password@localhost:5432/cleexs?schema=public"

# NextAuth / Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# API
API_URL="http://localhost:3001"
API_PORT=3001

# Logos de marcas (Logo.dev - gratis 5k/día en logo.dev/signup)
# Sin esto se usa Google Favicon cuando hay dominio, o inicial cuando no
NEXT_PUBLIC_LOGO_DEV_TOKEN=""

# Cloudflare Turnstile (captcha) - deshabilitado por ahora (URLs dinámicas de Vercel cambian en cada deploy)
# Si querés reactivarlo con dominio estable: NEXT_PUBLIC_TURNSTILE_SITE_KEY + TURNSTILE_SECRET_KEY

# Redis (para BullMQ)
REDIS_URL="redis://localhost:6379"

# OpenAI (Freemium + Gold: análisis del diagnóstico)
# En prod: Railway → API → Variables
OPENAI_API_KEY=""

# Gemini (Gold: análisis adicional con Google AI)
# En prod: Railway → API → Variables. Si falta, Gold usa solo OpenAI.
GOOGLE_AI_API_KEY=""
# Alternativa: GEMINI_API_KEY=""

# Email (diagnóstico público, envío directo)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@cleexs.com"
# Alternativas: SMTP_FROM_EMAIL (remitente), SMTP_FROM_NAME (nombre del remitente)
# FRONTEND_URL: URL del front para links en emails. CORS permite automáticamente *.vercel.app
FRONTEND_URL="http://localhost:3000"

# Sentry (opcional)
SENTRY_DSN=""
